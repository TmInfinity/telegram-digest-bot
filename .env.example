# Copy this file to `.env` and fill in your own values.
# NEVER commit your real .env — it is git-ignored on purpose.
# Recommended: chmod 600 .env

# --- Telegram API (your own account, the "userbot" that READS messages) ---
# Create an app at https://my.telegram.org -> API development tools
TG_API_ID=123456
TG_API_HASH=your_api_hash_here

# --- Telegram Bot (a separate BotFather bot that TALKS to you) ---
# Create a bot with @BotFather and paste its token here
TG_BOT_TOKEN=123456:ABC-your-bot-token

# Your own numeric chat id (the only user allowed to use the bot).
# Find it with: uv run python chatid_bul.py  (after sending /start to your bot)
TG_CHAT_ID=123456789

# --- Summarization model (OpenRouter, OpenAI-compatible) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Optional. Any OpenRouter model slug. Defaults to deepseek/deepseek-chat-v3-0324
# if unset. Free models (":free" suffix) work but are rate-limited.
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
